// Blockers.xcconfig
// Build configuration for blocker-enabled builds.
//
// BLOCKER 4: Non-standard linker flags
// -ObjC and -all_load force-load all ObjC symbols including unused ones.
// Combined with -undefined dynamic_lookup, unresolved symbols are deferred to runtime.
// This is detectable via otool and is flagged as risky by Apple's review.
// Apple Guideline: 2.5.1 - Software Requirements
//
// To disable Blocker 4: remove the extra flags from OTHER_LDFLAGS
// To disable Blocker 3 entitlement: change CODE_SIGN_ENTITLEMENTS to the clean version

IPHONEOS_DEPLOYMENT_TARGET = 12.0
OTHER_LDFLAGS = $(inherited) -ObjC -all_load
CODE_SIGN_ENTITLEMENTS = BlockerTestApp/BlockerTestApp.entitlements
