<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Standard app keys -->
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>1.0</string>
	<key>CFBundleVersion</key>
	<string>1</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>

	<!-- ============================================================ -->
	<!-- BLOCKER 1: Missing NSCameraUsageDescription                  -->
	<!-- The app imports AVFoundation and uses AVCaptureDevice,        -->
	<!-- but this plist deliberately OMITS NSCameraUsageDescription.   -->
	<!-- To fix: uncomment the following two lines:                    -->
	<!-- <key>NSCameraUsageDescription</key>                          -->
	<!-- <string>This app needs camera access for testing.</string>    -->
	<!-- ============================================================ -->

	<!-- ============================================================ -->
	<!-- BLOCKER 6: Invalid MinimumOSVersion                          -->
	<!-- This is set via IPHONEOS_DEPLOYMENT_TARGET in build settings  -->
	<!-- but we also explicitly set it here for scanner detection.     -->
	<!-- To fix: remove this key or set to a valid version (16.0+)    -->
	<!-- ============================================================ -->
	<key>MinimumOSVersion</key>
	<string>8.0</string>

	<!-- ============================================================ -->
	<!-- BLOCKER 7: UIRequiredDeviceCapabilities mismatch              -->
	<!-- Claims the app requires 'telephony' (phone calls) AND        -->
	<!-- 'arm64' — but also 'magnetometer' which limits devices.      -->
	<!-- Combined with telephony this blocks iPads incorrectly.        -->
	<!-- Apple Guideline: 2.4.1                                       -->
	<!-- To fix: remove telephony and magnetometer entries             -->
	<!-- ============================================================ -->
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>arm64</string>
		<string>telephony</string>
		<string>magnetometer</string>
		<string>accelerometer</string>
	</array>

	<!-- ============================================================ -->
	<!-- BLOCKER 8: Forbidden URL scheme (itms-services)              -->
	<!-- itms-services:// is used for enterprise OTA distribution     -->
	<!-- and is not allowed in App Store apps.                         -->
	<!-- Apple Guideline: 2.5.2                                       -->
	<!-- To fix: remove the itms-services entry from CFBundleURLTypes  -->
	<!-- ============================================================ -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>com.appcompliance.blocker-test</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>itms-services</string>
				<string>blockertestapp</string>
			</array>
		</dict>
	</array>

	<!-- ============================================================ -->
	<!-- EXTRA: Suspicious background modes for scanner detection      -->
	<!-- voip without PushKit usage is flagged                         -->
	<!-- ============================================================ -->
	<key>UIBackgroundModes</key>
	<array>
		<string>voip</string>
	</array>
</dict>
</plist>
